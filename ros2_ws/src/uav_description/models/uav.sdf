      <sensor name="logical_camera" type="logical_camera">
        <pose>0 0 0 0 1.5708 0</pose>
        <logical_camera>
          <near>0.5</near>
          <far>50.0</far>
          <horizontal_fov>2.618</horizontal_fov>
