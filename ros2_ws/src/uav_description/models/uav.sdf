<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="uav_1">
    <static>true</static>

    <plugin filename="gz-sim-logical-camera-system" name="gz::sim::systems::LogicalCamera"/>

    <link name="base_link">
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.02</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.02</iyy><iyz>0</iyz>
          <izz>0.04</izz>
        </inertia>
